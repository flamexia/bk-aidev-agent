{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // 覆盖基础配置中的开发相关设置
    "noEmit": false,
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    // 构建时不需要这些严格检查
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "playground/**/*"
  ]
}





